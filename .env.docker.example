# =============================================================================
# ClaimShield Santé — Variables d'environnement pour le déploiement Docker
# Copier ce fichier en .env.docker et renseigner les valeurs réelles.
# Référencé par docker-compose.yml (env_file) pour les services api/ui.
#
# Différences avec .env.example (dev local) :
#   - tous les chemins sont réécrits sous /app/... (racine du conteneur,
#     WORKDIR défini dans le Dockerfile) au lieu de chemins relatifs locaux ;
#   - OLLAMA_BASE_URL / LANGGRAPH_CHECKPOINT_BACKEND / LANGGRAPH_CHECKPOINT_DB /
#     CLAIMSHIELD_API_BASE_URL / CLAIMSHIELD_UI_UPLOAD_DIR sont déjà fixés
#     directement dans docker-compose.yml (bloc `environment:`, prioritaire
#     sur ce fichier) — laissés ici en commentaire pour référence uniquement.
# =============================================================================

# ── LLM : Ollama sur l'hôte (PAS embarqué dans un conteneur) ─────────────────
# OLLAMA_BASE_URL=http://host.docker.internal:11434   # déjà fixé dans docker-compose.yml
CLAIMSHIELD_LLM_MODEL=gemma4:latest
CLAIMSHIELD_LLM_PROVIDER=ollama

# ── Application ───────────────────────────────────────────────────────────────
CLAIMSHIELD_ENV=production
CLAIMSHIELD_DEBUG=false
CLAIMSHIELD_LOG_LEVEL=INFO
CLAIMSHIELD_SECRET_KEY=changez-cette-valeur-en-production-minimum-32-chars

# ── Serveur API FastAPI ───────────────────────────────────────────────────────
# Clé requise (en-tête X-API-Key) pour soumettre un dossier ou une décision
# humaine — voir api/dependencies.py. Changer impérativement en production.
CLAIMSHIELD_API_KEY=claimshield-dev-api-key-change-in-production

# ── Interface conversationnelle Chainlit (ui/) ────────────────────────────────
# CLAIMSHIELD_API_BASE_URL=http://api:8000            # déjà fixé dans docker-compose.yml
# CLAIMSHIELD_UI_UPLOAD_DIR=/app/storage/ui_uploads    # déjà fixé dans docker-compose.yml

# ── Dossiers de données (montés en volume, voir docker-compose.yml) ──────────
CLAIMSHIELD_DATASETS_DIR=/app/datasets
CLAIMSHIELD_STORAGE_DIR=/app/storage
CLAIMSHIELD_INBOX_DIR=/app/storage/inbox
CLAIMSHIELD_QUARANTINE_DIR=/app/storage/quarantine
CLAIMSHIELD_PROCESSED_DIR=/app/storage/processed
CLAIMSHIELD_REJECTED_DIR=/app/storage/rejected
CLAIMSHIELD_TEMP_DIR=/app/storage/temp

# ── Base de données (SQLite par défaut — fichier sous le volume storage/) ────
DATABASE_URL=sqlite+aiosqlite:////app/storage/claimshield.db

# ── LangGraph — persistance des checkpoints ───────────────────────────────────
# LANGGRAPH_CHECKPOINT_BACKEND=sqlite                  # déjà fixé dans docker-compose.yml
# LANGGRAPH_CHECKPOINT_DB=/app/storage/checkpoints.db  # déjà fixé dans docker-compose.yml

# ── Sécurité des fichiers déposés ────────────────────────────────────────────
CLAIMSHIELD_MAX_FILE_SIZE_MB=20
CLAIMSHIELD_MAX_FOLDER_SIZE_MB=200
CLAIMSHIELD_MAX_FILES_PER_FOLDER=50
CLAIMSHIELD_ALLOWED_EXTENSIONS=pdf,png,jpeg,jpg,json
CLAIMSHIELD_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,application/json

# ── Pseudonymisation (HMAC-SHA256) ───────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Ne jamais utiliser la valeur ci-dessous en production, ne jamais committer
# la clé réelle dans Git.
PSEUDONYMIZATION_KEY=replace-with-a-secure-random-key

# ── Audit ─────────────────────────────────────────────────────────────────────
CLAIMSHIELD_AUDIT_DIR=/app/logs/audit

# ── HITL — route de relance (correction humaine) ───────────────────────────────
CLAIMSHIELD_MAX_CORRECTION_ATTEMPTS=3

# ── Nœuds — retry technique automatique (erreurs transitoires) ────────────────
CLAIMSHIELD_MAX_NODE_RETRY_ATTEMPTS=3

# ── Case Reviewer — auto-approbation bornée (P1-4) ─────────────────────────────
CLAIMSHIELD_AUTO_APPROVE_CONFIDENCE_THRESHOLD=0.9
