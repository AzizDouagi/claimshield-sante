# =============================================================================
# ClaimShield Santé — Modèle de variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs réelles
# =============================================================================

# ── LLM : Ollama local ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
CLAIMSHIELD_LLM_MODEL=gemma4:latest
CLAIMSHIELD_LLM_PROVIDER=ollama

# ── Application ───────────────────────────────────────────────────────────────
CLAIMSHIELD_ENV=development
CLAIMSHIELD_DEBUG=true
CLAIMSHIELD_LOG_LEVEL=INFO
CLAIMSHIELD_SECRET_KEY=changez-cette-valeur-en-production-minimum-32-chars

# ── Serveur API FastAPI ───────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true
# Clé requise (en-tête X-API-Key) pour soumettre un dossier ou une décision
# humaine — voir api/dependencies.py. Changer impérativement en production.
CLAIMSHIELD_API_KEY=claimshield-dev-api-key-change-in-production

# ── Interface conversationnelle Chainlit (ui/) ────────────────────────────────
# URL de l'API que l'UI appelle — réutilise CLAIMSHIELD_API_KEY ci-dessus
# (un seul secret partagé, pas de clé séparée pour l'UI).
CLAIMSHIELD_API_BASE_URL=http://localhost:8000
# Répertoire où l'UI écrit les fichiers uploadés avant soumission à l'API —
# doit être un volume PARTAGÉ avec le conteneur api en déploiement Docker.
CLAIMSHIELD_UI_UPLOAD_DIR=./storage/ui_uploads

# ── Synthea — générateur de données synthétiques ──────────────────────────────
SYNTHEA_ROOT=./synthea
SYNTHEA_OUTPUT_DIR=./synthea/output_claimshield
CLAIMSHIELD_SOURCE_ROOT=./synthea/claimshield_cases

# ── Dossiers de données ───────────────────────────────────────────────────────
CLAIMSHIELD_DATASETS_DIR=./datasets
CLAIMSHIELD_STORAGE_DIR=./storage
CLAIMSHIELD_INBOX_DIR=./storage/inbox
CLAIMSHIELD_QUARANTINE_DIR=./storage/quarantine
CLAIMSHIELD_PROCESSED_DIR=./storage/processed
CLAIMSHIELD_REJECTED_DIR=./storage/rejected
CLAIMSHIELD_TEMP_DIR=./storage/temp

# ── Base de données (SQLite en dev — PostgreSQL en prod) ──────────────────────
DATABASE_URL=sqlite+aiosqlite:///./storage/claimshield.db
# DATABASE_URL=postgresql+asyncpg://user:motdepasse@localhost:5432/claimshield

# ── LangGraph — persistance des checkpoints ───────────────────────────────────
LANGGRAPH_CHECKPOINT_BACKEND=memory
LANGGRAPH_CHECKPOINT_DB=./storage/checkpoints.db
# LANGGRAPH_CHECKPOINT_BACKEND=postgres
# LANGGRAPH_CHECKPOINT_POSTGRES_URL=postgresql://user:motdepasse@localhost:5432/claimshield

# ── Sécurité des fichiers déposés ────────────────────────────────────────────
CLAIMSHIELD_MAX_FILE_SIZE_MB=20
CLAIMSHIELD_MAX_FOLDER_SIZE_MB=200
CLAIMSHIELD_MAX_FILES_PER_FOLDER=50
CLAIMSHIELD_ALLOWED_EXTENSIONS=pdf,png,jpeg,jpg,json
CLAIMSHIELD_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,application/json

# ── Pseudonymisation (HMAC-SHA256) ───────────────────────────────────────────
# Clé secrète utilisée pour pseudonymiser les identifiants patients.
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Ne jamais utiliser la valeur ci-dessous en production.
# Ne jamais committer la clé réelle dans Git.
PSEUDONYMIZATION_KEY=replace-with-a-secure-random-key

# ── Audit ─────────────────────────────────────────────────────────────────────
CLAIMSHIELD_AUDIT_DIR=./logs/audit

# ── HITL — route de relance (correction humaine) ───────────────────────────────
# Nombre maximal de relances (NEEDS_MORE_INFO) après await_human_review avant
# de router vers failure — empêche toute boucle infinie de corrections.
CLAIMSHIELD_MAX_CORRECTION_ATTEMPTS=3

# ── Nœuds — retry technique automatique (erreurs transitoires) ────────────────
# Nombre maximal de tentatives (première incluse) pour un nœud agent en cas
# d'erreur réseau/timeout transitoire, avant de basculer sur le repli structuré.
# N'affecte pas les erreurs non transitoires (bug, panne non catégorisée).
CLAIMSHIELD_MAX_NODE_RETRY_ATTEMPTS=3

# ── Case Reviewer — auto-approbation bornée (P1-4) ─────────────────────────────
# Seuil minimal de confiance LLM requis, en plus des autres critères (Phase A
# déjà APPROVE sans motif, LLM disponible et non-escaladant), pour que
# case_reviewer_agent pose result_payload.auto_decision="AUTO_APPROVED_LOW_RISK".
# N'affecte jamais le verrou status=NEEDS_REVIEW/human_review_required=True.
CLAIMSHIELD_AUTO_APPROVE_CONFIDENCE_THRESHOLD=0.9

# ── Chat Reasoning Agent — mémoire conversationnelle (Phase 8, V2) ─────────────
# Durée de vie (secondes) d'une conversation entière avant expiration
# (chat.conversation_store.ConversationStore.expire_older_than) — retire
# toujours une conversation complète, jamais un tour isolé. Défaut 1h.
CLAIMSHIELD_CHAT_MEMORY_TTL_SECONDS=3600
