# =============================================================================
# ClaimShield Santé — Modèle de variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs réelles
# =============================================================================

# ── LLM : Ollama local ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
CLAIMSHIELD_LLM_MODEL=gemma4:latest
CLAIMSHIELD_LLM_PROVIDER=ollama

# ── Application ───────────────────────────────────────────────────────────────
CLAIMSHIELD_ENV=development
CLAIMSHIELD_DEBUG=true
CLAIMSHIELD_LOG_LEVEL=INFO
CLAIMSHIELD_SECRET_KEY=changez-cette-valeur-en-production-minimum-32-chars

# ── Serveur API FastAPI ───────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# ── Synthea — générateur de données synthétiques ──────────────────────────────
SYNTHEA_ROOT=/path/to/synthea
SYNTHEA_OUTPUT_DIR=/path/to/synthea/output_claimshield
CLAIMSHIELD_SOURCE_ROOT=/path/to/synthea/claimshield_cases

# ── Dossiers de données ───────────────────────────────────────────────────────
CLAIMSHIELD_DATASETS_DIR=./datasets
CLAIMSHIELD_STORAGE_DIR=./storage
CLAIMSHIELD_INBOX_DIR=./storage/inbox
CLAIMSHIELD_QUARANTINE_DIR=./storage/quarantine
CLAIMSHIELD_PROCESSED_DIR=./storage/processed
CLAIMSHIELD_REJECTED_DIR=./storage/rejected
CLAIMSHIELD_TEMP_DIR=./storage/temp

# ── Base de données (SQLite en dev — PostgreSQL en prod) ──────────────────────
DATABASE_URL=sqlite+aiosqlite:///./storage/claimshield.db
# DATABASE_URL=postgresql+asyncpg://user:motdepasse@localhost:5432/claimshield

# ── LangGraph — persistance des checkpoints ───────────────────────────────────
LANGGRAPH_CHECKPOINT_DB=./storage/checkpoints.db
# LANGGRAPH_CHECKPOINT_URI=postgresql+asyncpg://user:motdepasse@localhost:5432/claimshield

# ── Sécurité des fichiers déposés ────────────────────────────────────────────
CLAIMSHIELD_MAX_FILE_SIZE_MB=20
CLAIMSHIELD_MAX_FOLDER_SIZE_MB=200
CLAIMSHIELD_MAX_FILES_PER_FOLDER=50
CLAIMSHIELD_ALLOWED_EXTENSIONS=pdf,png,jpeg,jpg,json
CLAIMSHIELD_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,application/json

# ── Pseudonymisation (HMAC-SHA256) ───────────────────────────────────────────
# Clé secrète utilisée pour pseudonymiser les identifiants patients.
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# Ne jamais utiliser la valeur ci-dessous en production.
# Ne jamais committer la clé réelle dans Git.
PSEUDONYMIZATION_KEY=replace-with-a-secure-random-key

# ── Audit ─────────────────────────────────────────────────────────────────────
CLAIMSHIELD_AUDIT_DIR=./logs/audit
